# Required
OPENAI_API_KEY=sk-...

# Optional — defaults shown
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# VISION_MODEL=gpt-4o
# OUTPUT_DIR=./output
# EXEC_TIMEOUT=240
# MAX_FIX_RETRIES=3
# LLM_TIMEOUT=180

# Series length policy. Defaults favour concept-exploration.
# Set higher to study within-series drift in detail.
# MIN_SERIES_LEN=7
# SOFT_MAX_SERIES_LEN=12
# HARD_MAX_SERIES_LEN=15

# Approximate total number of series planned for this run. Drives the
# explore/exploit framing shown to the model — early on it should
# explore broadly, later it should lean on its accumulated library to
# make work recognizable as its own. Set to 0 to disable progress framing.
# EXPECTED_SERIES=12

# Rendered image side, in pixels. Keep in sync with downstream consumers
# (e.g. make_video.py). Injected into the prompt so the LLM doesn't
# hardcode a mismatched resolution.
# IMAGE_SIZE=1024

# Perceptual-similarity bucket thresholds. sim >= STRONG => 'strong_repeat',
# sim >= MILD => 'mild_repeat', else 'novel'. Shown to the model verbatim.
# SIM_STRONG_REPEAT=0.80
# SIM_MILD_REPEAT=0.60

# Visual memory shown to step 1:
#   STEP1_SERIES_SURVEY      — k in-series reference images (excl. latest)
#   STEP1_PAST_SERIES_SURVEY — last frame of each of the N prior series,
#                              only when opening a new series
# STEP1_SERIES_SURVEY=2
# STEP1_PAST_SERIES_SURVEY=4

# Rolling window for the harness-side perceptual-similarity report.
# SIMILARITY_WINDOW=6

# Rewrite artistic_path only on series boundaries by default.
# Set N>0 to also rewrite every N iterations.
# PATH_REWRITE_EVERY=0

# Interpreter used to run the LLM-generated art.py.
# Must have pillow, numpy, scipy, noise installed.
# Auto-detects ./.venv/bin/python if unset.
# ART_PYTHON=./.venv/bin/python
