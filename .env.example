# Required
OPENAI_API_KEY=sk-...

# Optional — defaults shown
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# VISION_MODEL=gpt-4o
# OUTPUT_DIR=./output
# EXEC_TIMEOUT=240
# MAX_FIX_RETRIES=3
# LLM_TIMEOUT=180

# Interpreter used to run the LLM-generated art.py.
# Must have pillow, numpy, scipy, noise installed.
# Auto-detects ./.venv/bin/python if unset.
# ART_PYTHON=./.venv/bin/python
